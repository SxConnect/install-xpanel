# ============================================
# XPanel Client - Configuração
# ============================================

# URL do XPanel Master (servidor central)
# Este é o servidor onde o catálogo está hospedado
MASTER_URL=http://localhost:5000

# Porta onde o XPanel Client vai rodar
CLIENT_PORT=3000

# Identificação desta instalação
# Gere um ID único para cada instalação
INSTANCE_ID=client-$(uuidgen)
INSTANCE_NAME=Minha Empresa
INSTANCE_EMAIL=admin@minhaempresa.com

# Versão do XPanel Client
VERSION=latest
